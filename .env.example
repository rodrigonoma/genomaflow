DATABASE_URL=postgres://postgres:postgres@db:5432/genomaflow
DATABASE_URL_TEST=postgres://postgres:postgres@localhost:5432/genomaflow_test
REDIS_URL=redis://redis:6379
JWT_SECRET=change_me_in_production
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY_HERE
UPLOADS_DIR=/tmp/uploads

# === MODELOS IA (opcional, defaults em apps/{api,worker}/src/config/models.js) ===
# Override para experimentar trocas de modelo sem deploy de código. Defaults
# atuais entre parênteses. Sincronizar valor no worker E na api (alguns são
# usados nos dois packages).
# MODEL_CLINICAL_AGENT=claude-opus-4-6      # agentes clínicos de texto (worker)
# MODEL_CLINICAL_PREMIUM=claude-opus-4-7    # IA pró-ativa, co-piloto, transcrição vídeo
# MODEL_VISION=claude-sonnet-4-6            # agentes imagem + foto laudo + chat answer
# MODEL_UTILITY=claude-haiku-4-5-20251001   # OCR, PII redact, chat search, copilot ajuda
# OCR_MODEL=                                 # legacy override só pra OCR de PDF (fallback MODEL_UTILITY)
# PRODUCT_HELP_MODEL=                        # legacy override só pro copilot ajuda (fallback MODEL_UTILITY)

# === STRIPE ===
# 1. Pegue chaves de teste em https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
#
# 2. Crie um Product em https://dashboard.stripe.com/test/products
#    "Plano Mensal R$ 199" com price recurring monthly em BRL.
#    Cole o price_id aqui:
STRIPE_PRICE_SUBSCRIPTION=price_xxxxxxxxxxxxxxxxxxxxxxxxxx
#
# 3. Pra rodar webhook em dev, instale Stripe CLI e rode:
#    stripe listen --forward-to localhost:3000/api/webhooks/stripe
#    A CLI vai imprimir um whsec_... — cole aqui:
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
